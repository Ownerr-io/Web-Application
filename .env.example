# =============================================================================
# Ownerr monorepo — environment template
# Copy to .env.local for local development (see supabase/README.md)
# =============================================================================
# Production (Vercel + Supabase BaaS): see docs/architecture/production-supabase-baas.md
# Required on Vercel: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_PUBLIC_SITE_URL
# No separate backend server — marketplace buyer/seller uses Supabase RPC + RLS only.

# --- Vite web app (artifacts/ownerr-web-app) ---
VITE_PUBLIC_SITE_URL=https://ownerr.live
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: show which seeded demo emails exist (auth is still via Supabase DB). Run: npm run marketplace:seed-demo
# Passwords are set only in scripts/demo-marketplace.constants.mjs — not in Vite env.
VITE_ENABLE_DEMO_USERS=false

# Platform admin: set in Postgres (public.users.role = 'admin'), not in Vite env.
# Example (SQL editor / migration): update public.users set role = 'admin' where email = 'you@company.com';

# PostHog product analytics (admin CRUD + page views)
# VITE_POSTHOG_KEY=phc_your_project_key
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# Optional: Supabase email OTP length for reauthentication UI (default 8)
# VITE_AUTH_OTP_LENGTH=8

# --- Optional: legacy artifacts/api-server (not used in production) ---
PORT=5001
NODE_ENV=development
# Direct connection (Dashboard → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# If direct times out (common on restricted networks), add Session pooler URI from same page
# (host is aws-0- or aws-1-<region>.pooler.supabase.com — copy exactly from the dashboard):
# DATABASE_URL_POOLER=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
# DATABASE_URL_MIGRATE=…  # optional: force migrate script to use pooler only (skips slow direct timeout)
# If direct hangs on IPv6-only hosts, do not set DATABASE_IPV4_ONLY=1 (only use when IPv6 is broken).
PUBLIC_SITE_URL=https://ownerr.live
FOUNDER_ADMIN_SECRET=change-me-local-admin-key
LOG_LEVEL=info
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Integration credentials (v1) — encrypt at rest in Postgres; never in Vite env ---
# Primary key material (32+ chars): openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY=
# Pepper (16+ chars, recommended): openssl rand -base64 24 — combined via SHA-256 in DB (not stored in ciphertext).
# INTEGRATION_ENCRYPTION_PEPPER=
# After setting keys: npm run platform:set-integration-secrets

# After setting keys: npm run platform:set-integration-secrets
# (Worker URLs below are optional — only for seller listing verification async jobs.)

# --- Optional: verification async jobs (NOT required for marketplace desk) ---
# Local full verification dev: npm run dev:with-verification-worker
# SYNC_WORKER_ID=sync-worker-1
# SYNC_POLL_MS=5000
# SYNC_WORKER_HTTP=1
# SYNC_WORKER_HTTP_PORT=8787
# SYNC_WORKER_CRON_SECRET=  # openssl rand -base64 32
#
# After changing production URLs: npm run platform:set-integration-secrets && npm run verification:config-check
# Store invoke URLs in Postgres (sys_platform_config) when you enable async verification:
# SYNC_WORKER_PUBLIC_URL=https://ownerr.live/api/sync-worker
# SYNC_WORKER_INVOKE_URL=https://ownerr.live/api/sync-worker/v1/process-jobs
# Or point at Supabase Edge Function URLs instead of a separate worker host.
# Vercel-only legacy proxy (optional): SYNC_WORKER_INTERNAL_URL=...
# Vite dev proxy (optional): VITE_SYNC_WORKER_PROXY_TARGET=http://127.0.0.1:8787
# Public site origin only (no path) — verification return URLs are built in the worker
# MARKETPLACE_PUBLIC_URL=https://ownerr.live
# Local: MARKETPLACE_PUBLIC_URL=http://localhost:5173
# RESEND_API_KEY=re_...  # only if your async handler sends business-email (not Vite)
# Do NOT set platform STRIPE_SECRET_KEY for production — sellers supply Stripe/revenue keys in the app;
# they are encrypted in Supabase and used when verification jobs run.
# STRIPE_IDENTITY_WEBHOOK_SECRET / STRIPE_SECRET_KEY below are legacy local-worker fallbacks and CI smoke tests only.
# STRIPE_SECRET_KEY=sk_...
# STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...
# Local Stripe CLI: stripe listen --forward-to http://localhost:5173/api/webhooks/stripe/identity
# VERIFICATION_OCR_PROVIDER=google_document_ai
# GOOGLE_DOCUMENT_AI_PROJECT_ID=
# GOOGLE_DOCUMENT_AI_LOCATION=us
# GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# REGISTRATION_DOCS_BUCKET=verification-documents  # default; legacy bucket registration_docs uses same RLS paths
# REVALIDATION_SWEEP_MS=3600000  # sync worker periodic gate refresh (default 1h)
# REVENUE_SMOKE_PROBE_UNCONFIGURED=1  # default: hit vendor APIs even without keys (auth errors OK)
# Per-provider live API smoke (real keys only — no mocks). Also uses seller desk connections via service role.
# REVENUE_SMOKE_STRIPE_SECRET=sk_test_...
# REVENUE_SMOKE_PADDLE_API_KEY=
# REVENUE_SMOKE_REVENUECAT_API_KEY=  + REVENUE_SMOKE_REVENUECAT_PROJECT_ID=
# REVENUE_SMOKE_CHARGEBEE_API_KEY=  + REVENUE_SMOKE_CHARGEBEE_SITE=
# REVENUE_SMOKE_RECURLY_API_KEY=  + REVENUE_SMOKE_RECURLY_SUBDOMAIN=
# REVENUE_SMOKE_LEMONSQUEEZY_API_KEY=
# REVENUE_SMOKE_RAZORPAY_CREDENTIALS=key_id:key_secret
# REVENUE_SMOKE_PAYPAL_TOKEN_JSON={"access_token":"..."}
# REVENUE_SMOKE_SQUARE_TOKEN_JSON={"access_token":"..."}
# REVENUE_SMOKE_PAYU_API_KEY=
# REVENUE_SMOKE_SHOPIFY_SHOP=myshop.myshopify.com  + REVENUE_SMOKE_SHOPIFY_ACCESS_TOKEN=
# REVENUE_SMOKE_WOOCOMMERCE_STORE_URL=  + REVENUE_SMOKE_WOOCOMMERCE_CREDENTIALS=key:secret
# REVENUE_SMOKE_BIGCOMMERCE_STORE_HASH=  + REVENUE_SMOKE_BIGCOMMERCE_ACCESS_TOKEN=
# REVENUE_SMOKE_QUICKBOOKS_TOKEN_JSON=  + REVENUE_SMOKE_QUICKBOOKS_REALM_ID=
# REVENUE_SMOKE_XERO_TOKEN_JSON=  + REVENUE_SMOKE_XERO_TENANT_ID=
# REVENUE_SMOKE_ZOHO_BOOKS_TOKEN_JSON=  + REVENUE_SMOKE_ZOHO_BOOKS_ORG_ID=
# REVENUE_SMOKE_PLAID_ACCESS_TOKEN=  (or REVENUE_SMOKE_PLAID_TOKEN_JSON)
# REVENUE_SMOKE_TINK_TOKEN_JSON=
# Run: npm run test:revenue-providers

# --- Auth email (Resend SMTP in Supabase Dashboard — not Vite) ---
# Production: Authentication → SMTP (smtp.resend.com, port 465, user resend, password = API key)
# Sender: Ownerr Intelligence <Intelligence@ownerr.live>
# Optional local hook path is disabled; do not put RESEND_API_KEY in VITE_*.

# Founder admin analytics: update Supabase table (not .env):
#   update public.founder_admin_secrets set secret = 'your-key' where id = 1;
