{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "artifacts/ownerr-web-app/dist",
  "framework": "vite",
  "root": "artifacts/ownerr-web-app",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
